# .env.example — Copiar como .env y completar valores reales
# NUNCA subir .env al repositorio (está en .gitignore)

# Base de datos
DB_NAME=jardin_db
DB_USER=jardin_user
DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# Backend JWT
SECRET_KEY=GENERA-UN-SECRET-SEGURO-CON-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS (solo si usas S3 local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Frontend
# /api/v1 usa el proxy local de Vite/Nginx. Si ejecutas backend directo,
# puedes usar http://localhost:8000/api/v1.
VITE_API_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WHATSAPP_PHONE=
